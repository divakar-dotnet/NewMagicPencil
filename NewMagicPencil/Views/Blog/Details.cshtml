@model NewMagicPencil.Models.Blog
@{
    ViewData["Title"] = "Blog Details";
}

<div class="card shadow-sm p-4">
    <h2>@Model.Title</h2>
    <p class="text-muted small"><b>Posted:</b> @Model.PostedDate.ToString("dd MMM yyyy HH:mm")</p>
    <hr />
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <div class="text-center mb-4">
            <img src="@Model.ImageUrl" style="max-width:100%;height:auto;border-radius:8px;" class="shadow-sm" />
        </div>
    }
    <div class="mt-3">@Html.Raw(Model.Content)</div>
    @if (!string.IsNullOrEmpty(Model.Hashtags))
    {
        <div class="mt-4"><span class="badge bg-primary">@Model.Hashtags</span></div>
    }
    <div class="mt-4">
        <a asp-action="Index" class="btn btn-dark px-4"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>