@model NewMagicPencil.Controllers.BlogFormModel
@{
    ViewData["Title"] = "Edit Blog";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil-square"></i> Edit Blog</h2>
    <a asp-action="Index" class="btn btn-outline-dark"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form id="editForm" asp-action="Edit" asp-route-id="@ViewBag.BlogId" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                <input asp-for="Title" id="titleInput" class="form-control" />
                <div class="field-error text-danger small mt-1" id="titleError"></div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Short Description <span class="text-danger">*</span></label>
                <textarea asp-for="ShortDescription" id="shortDescInput" class="form-control" rows="3"></textarea>
                <div class="field-error text-danger small mt-1" id="shortDescError"></div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Content <span class="text-danger">*</span></label>
                <div id="quillEditor" style="min-height: 250px; background: #fff;"></div>
                <textarea id="Content" name="Content" style="display:none;">@Model.Content</textarea>
                <div class="field-error text-danger small mt-1" id="contentError"></div>
            </div>

            @if (ViewBag.ExistingImage != null)
            {
                <div class="mb-3" id="existingImageContainer">
                    <label class="form-label fw-semibold d-block">Current Image</label>
                    <img src="@ViewBag.ExistingImage" width="120" class="img-thumbnail shadow-sm" />
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-semibold">Change Image (Optional)</label>
                <input type="file" asp-for="Image" id="imageInput" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Tags</label>
                <input asp-for="Hashtags" id="tagsInput" class="form-control" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" id="saveBtn" class="btn btn-success px-4">
                    <span class="btn-text"><i class="bi bi-save"></i> Update</span>
                    <span class="spinner-border spinner-border-sm d-none ms-1"></span>
                </button>

                <button type="button" id="clearBtn" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-eraser"></i> Clear
                </button>

                <a asp-action="Index" class="btn btn-dark px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />

<style>
    .field-error {
        display: none;
    }

        .field-error.show {
            display: block !important;
        }

    .border-invalid {
        border-color: #d63031 !important;
    }

    .ql-container.border-invalid {
        border: 1px solid #d63031 !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script>
        // Initialize Quill
        const quill = new Quill('#quillEditor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline'],
                    [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                    ['link', 'clean']
                ]
            }
        });

        // Load existing content into Quill
        const existingContent = document.getElementById('Content').value;
        if (existingContent) {
            quill.root.innerHTML = existingContent;
        }

        // ── CLEAR BUTTON LOGIC ──
        document.getElementById('clearBtn').addEventListener('click', function() {
            // 1. Wipe text fields
            document.getElementById('titleInput').value = "";
            document.getElementById('shortDescInput').value = "";
            document.getElementById('tagsInput').value = "";
            document.getElementById('imageInput').value = ""; // Clear file picker

            // 2. Clear Quill Editor
            quill.setContents([]);

            // 3. Remove validation UI
            document.querySelectorAll('.field-error').forEach(el => el.classList.remove('show'));
            document.querySelectorAll('.form-control').forEach(el => el.classList.remove('border-invalid'));
            document.querySelector('.ql-container').classList.remove('border-invalid');
        });

        // Form Submit Validation
        document.getElementById('editForm').addEventListener('submit', function (e) {
            var title = document.getElementById('titleInput').value.trim();
            var shortDesc = document.getElementById('shortDescInput').value.trim();
            var quillText = quill.getText().trim();
            var valid = true;

            if (!title) {
                document.getElementById('titleError').innerText = "Title is required";
                document.getElementById('titleError').classList.add('show');
                document.getElementById('titleInput').classList.add('border-invalid');
                valid = false;
            }

            if (!shortDesc) {
                document.getElementById('shortDescError').innerText = "Short description is required";
                document.getElementById('shortDescError').classList.add('show');
                document.getElementById('shortDescInput').classList.add('border-invalid');
                valid = false;
            }

            if (quillText.length === 0) {
                document.getElementById('contentError').innerText = "Content is required";
                document.getElementById('contentError').classList.add('show');
                document.querySelector('.ql-container').classList.add('border-invalid');
                valid = false;
            }

            if (!valid) {
                e.preventDefault();
            } else {
                document.getElementById('Content').value = quill.root.innerHTML;
                document.getElementById('saveBtn').disabled = true;
                document.querySelector('.spinner-border').classList.remove('d-none');
            }
        });
    </script>
}