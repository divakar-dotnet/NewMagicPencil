@model NewMagicPencil.Controllers.BlogFormModel
@{
    ViewData["Title"] = "Edit Blog";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil-square"></i> Edit Blog</h2>
    <a asp-action="Index" class="btn btn-outline-dark"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form id="editForm" asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Title <span class="text-danger">*</span>
                </label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Short Description <span class="text-danger">*</span>
                </label>
                <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
                <span asp-validation-for="ShortDescription" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Content <span class="text-danger">*</span>
                </label>

                @* Quill editor — existing content loaded via JS below *@
                <div id="quillEditor" style="min-height:250px;"></div>

                @* Hidden textarea — holds existing HTML, updated before submit *@
                <textarea id="Content" name="Content" style="display:none;">@Model.Content</textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            @if (ViewBag.ExistingImage != null)
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Current Image</label><br />
                    <img src="@ViewBag.ExistingImage" width="150" class="img-thumbnail" />
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-semibold">Change Image (Optional)</label>
                <input type="file" asp-for="Image" class="form-control"
                       accept=".jpg,.jpeg,.png,.gif,.webp" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Tags</label>
                <input asp-for="Hashtags" class="form-control" />
            </div>

            <button type="submit" id="updateBtn" class="btn btn-success px-4">
                <span class="btn-text"><i class="bi bi-save"></i> Update</span>
                <span class="spinner-border spinner-border-sm d-none ms-1"></span>
            </button>
            <a asp-action="Index" class="btn btn-dark px-4 ms-2">Cancel</a>
        </form>
    </div>
</div>

@* Quill CSS *@
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />

<style>
    .ql-tooltip {
        display: none !important;
    }

    .ql-toolbar.ql-snow {
        border: 1px solid #dee2e6;
        border-radius: 6px 6px 0 0;
        background: #f8f9fa;
    }

    .ql-container.ql-snow {
        border: 1px solid #dee2e6;
        border-top: none;
        border-radius: 0 0 6px 6px;
        font-size: 1rem;
    }

    .ql-editor {
        min-height: 250px;
    }

    a[href*="quilljs"] {
        display: none !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script>
        // ── INIT QUILL ─────────────────────────────────────────────
        const quill = new Quill('#quillEditor', {
            theme: 'snow',
            placeholder: 'Write your blog content here...',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'color': [] }, { 'background': [] }],
                    [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                    [{ 'indent': '-1' }, { 'indent': '+1' }],
                    [{ 'align': [] }],
                    ['link'],
                    ['blockquote', 'code-block'],
                    ['clean']
                ]
            }
        });

        // ── LOAD EXISTING CONTENT INTO QUILL ──────────────────────
        const existingContent = document.getElementById('Content').value;
        if (existingContent && existingContent.trim().length > 0) {
            quill.root.innerHTML = existingContent;
        }

        // ── BEFORE SUBMIT — copy Quill HTML into hidden textarea ───
        document.getElementById('editForm').addEventListener('submit', function (e) {
            const content = quill.root.innerHTML;

            if (quill.getText().trim().length === 0) {
                e.preventDefault();
                document.querySelector('[data-valmsg-for="Content"]').textContent = 'Content is required.';
                return;
            }

            document.getElementById('Content').value = content;

            const btn = document.getElementById('updateBtn');
            btn.querySelector('.btn-text').innerHTML = '<i class="bi bi-hourglass-split"></i> Updating...';
            btn.querySelector('.spinner-border').classList.remove('d-none');
            btn.disabled = true;
        });
    </script>
}