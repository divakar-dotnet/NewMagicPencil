@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Error - Magic Pencil</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background: #f4f7f6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .error-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.10);
            padding: 48px 40px 36px;
            max-width: 560px;
            width: 100%;
            text-align: center;
        }

        .error-icon {
            font-size: 4.5rem;
            color: #d63031;
            animation: shake 0.5s ease;
        }
        @@keyframes shake {
            0%, 100% {
                transform: translateX(0);
            }

            20%, 60% {
                transform: translateX(-6px);
            }

            40%, 80% {
                transform: translateX(6px);
            }
        }

        h2 {
            color: #2d3436;
            font-weight: 700;
            margin-top: 12px;
        }

        .error-detail-box {
            background: #fff5f5;
            border: 1px solid #fab1b1;
            border-radius: 10px;
            padding: 16px 20px;
            margin: 20px 0;
            text-align: left;
        }

            .error-detail-box .label {
                font-size: 0.75rem;
                font-weight: 600;
                color: #b2bec3;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .error-detail-box .value {
                font-size: 0.9rem;
                color: #2d3436;
                word-break: break-word;
                margin-top: 2px;
            }

        .divider {
            border-top: 1px solid #f0f0f0;
            margin: 12px 0;
        }

        .btn-home {
            background: #6c5ce7;
            color: white;
            border: none;
            padding: 11px 32px;
            border-radius: 8px;
            font-size: 0.95rem;
            text-decoration: none;
            display: inline-block;
            margin-top: 8px;
            transition: background 0.2s;
        }

            .btn-home:hover {
                background: #5b4cc4;
                color: white;
            }

        .support-text {
            font-size: 0.8rem;
            color: #b2bec3;
            margin-top: 16px;
        }
    </style>
</head>
<body>
    <div class="error-card">
        <div class="error-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>

        <h2>Something went wrong!</h2>
        <p class="text-muted">
            An unexpected error occurred. The details have been recorded
            and our team will fix it shortly.
        </p>

        <!-- Error Detail Box -->
        <div class="error-detail-box">
            <div class="label">Error Message</div>
            <div class="value">@ViewBag.ErrorMessage</div>

            <div class="divider"></div>

            <div class="label">Occurred On Page</div>
            <div class="value">/@ViewBag.PageName</div>

            <div class="divider"></div>

            <div class="label">Time</div>
            <div class="value">@ViewBag.ErrorTime</div>
        </div>

        <a href="/Dashboard/Index" class="btn-home">
            <i class="bi bi-house-fill"></i> Go to Dashboard
        </a>

        <p class="support-text">
            If this keeps happening, contact support at
            <strong>divakar@duffldigital.com</strong>
        </p>
    </div>
</body>
</html>