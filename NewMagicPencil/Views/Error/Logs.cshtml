@model List<NewMagicPencil.Models.ErrorLog>
@{
    ViewData["Title"] = "Error Logs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-bug-fill text-danger"></i> Error Logs</h2>
    <form asp-action="ClearAll" method="post"
          onsubmit="return confirm('Delete ALL error logs? This cannot be undone.')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-trash"></i> Clear All
        </button>
    </form>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success py-2 small">@TempData["Success"]</div>
}

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-danger">@ViewBag.TotalCount</div>
            <div class="text-muted small">Total Errors</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-warning">@ViewBag.TodayCount</div>
            <div class="text-muted small">Today's Errors</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-primary">@ViewBag.TotalPages</div>
            <div class="text-muted small">Total Pages</div>
        </div>
    </div>
</div>

<!-- Search -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" asp-action="Logs" class="row g-2 align-items-end">
            <div class="col-md-8">
                <input type="text" name="search" value="@ViewBag.SearchTerm"
                       class="form-control form-control-sm"
                       placeholder="Search by error message or page name..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-dark btn-sm w-100">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
            <div class="col-md-2">
                <a asp-action="Logs" class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-x-circle"></i> Reset
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-check-circle fs-2 text-success"></i>
                <p class="mt-2 mb-0">No errors found. Everything is running smoothly! 🎉</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Error Message</th>
                        <th style="width:180px">Page</th>
                        <th style="width:160px">Added Date</th>
                        <th style="width:70px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="text-muted small">@log.Id</td>
                            <td class="small" title="@log.ErrorMessage">
                                @(log.ErrorMessage?.Length > 120
                                                        ? log.ErrorMessage.Substring(0, 120) + "..."
                                                        : log.ErrorMessage)
                            </td>
                            <td class="small text-truncate" style="max-width:180px"
                                title="@log.PageName">
                                <i class="bi bi-link-45deg text-muted"></i> @log.PageName
                            </td>
                            <td class="small text-nowrap">
                                <i class="bi bi-clock text-muted"></i>
                                @log.AddedDate.ToString("dd-MM-yyyy HH:mm:ss")
                            </td>
                            <td>
                                <form asp-action="Delete" method="post"
                                      onsubmit="return confirm('Delete this log?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@log.Id" />
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger py-0 px-2">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-end mb-0">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Logs"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.SearchTerm">@i</a>
                </li>
            }
        </ul>
    </nav>
}
<p class="text-muted small text-end mt-1">
    Showing @Model.Count of @ViewBag.TotalCount errors
</p>