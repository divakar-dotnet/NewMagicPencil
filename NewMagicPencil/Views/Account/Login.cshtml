@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Magic Pencil - Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background: #f4f7f6;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .login-box {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0px 10px 25px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 420px;
        }
        .btn-magic { background: #6c5ce7; color: white; border: none; }
        .btn-magic:hover { background: #5b4cc4; color: white; }
        .btn-link-magic {
            color: #6c5ce7; cursor: pointer;
            background: none; border: none; padding: 0; font-size: 0.875rem;
        }
        .btn-link-magic:hover { color: #5b4cc4; text-decoration: underline; }
        #errorAlert { transition: opacity 1s ease-out; }
        #errorAlert.fade-out { opacity: 0; }
        .step { display: none; }
        .step.active { display: block; }
        .otp-input {
            letter-spacing: 8px; font-size: 1.4rem;
            text-align: center; font-weight: bold;
        }
        .strength-bar { height: 5px; border-radius: 3px; transition: all 0.3s; margin-top: 5px; }
        .validation-item { font-size: 0.78rem; }
        .validation-item.valid { color: #00b894; }
        .validation-item.invalid { color: #d63031; }
        .field-error {
            color: #d63031;
            font-size: 0.8rem;
            margin-top: 4px;
            display: none;
        }
        .field-error.show { display: block !important; }
        .form-control.is-invalid { border-color: #d63031; box-shadow: none; }
    </style>
</head>
<body>
    <div class="login-box">

        <!-- LOGIN FORM -->
        <div id="loginSection">
            <h2 class="text-center mb-4">&#10024; Magic Pencil</h2>
            <form method="post" id="loginForm" novalidate>
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="text" name="email" id="loginEmail" class="form-control" placeholder="Enter email" />
                    <div class="field-error" id="emailError"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" id="loginPassword" class="form-control" placeholder="Enter password" />
                    <div class="field-error" id="passwordError"></div>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div id="errorAlert" class="alert alert-danger py-2">@ViewBag.Error</div>
                }

                <button type="submit" id="loginBtn" class="btn btn-magic w-100 py-2 mb-3">
                    <span id="loginText">Sign In</span>
                    <span id="loginSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
                <div class="text-center">
                    <button type="button" class="btn-link-magic" onclick="showForgotPassword()">
                        &#128273; Forgot Password ?
                    </button>
                </div>
            </form>
        </div>

        <!-- FORGOT PASSWORD FLOW -->
        <div id="forgotSection" style="display:none;">

            <!-- STEP 1 -->
            <div id="step1" class="step active">
                <h5 class="text-center mb-1">&#128273; Forgot Password ?</h5>
                <p class="text-muted text-center small mb-4">Enter your registered email to receive an OTP</p>
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="text" id="fpEmail" class="form-control" placeholder="Enter your email" />
                </div>
                <div id="step1Alert"></div>
                <button class="btn btn-magic w-100 py-2 mb-3" onclick="sendOtp()">
                    <span id="sendOtpText">Send OTP</span>
                    <span id="sendOtpSpinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
                </button>
                <div class="text-center">
                    <button class="btn-link-magic" onclick="showLogin()">&#8592; Back to Login</button>
                </div>
            </div>

            <!-- STEP 2 -->
            <div id="step2" class="step">
                <h5 class="text-center mb-1">&#128231; Enter OTP</h5>
                <p class="text-muted text-center small mb-1">We sent a 5-digit OTP to <strong id="displayEmail"></strong></p>
                <p class="text-center small mb-4"><span id="otpTimer" class="text-danger fw-bold"></span></p>
                <div class="mb-3">
                    <label class="form-label">OTP Code</label>
                    <input type="text" id="otpInput" class="form-control otp-input"
                           placeholder="_ _ _ _ _" maxlength="5"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>
                <div id="step2Alert"></div>
                <button class="btn btn-magic w-100 py-2 mb-2" onclick="verifyOtp()">
                    <span id="verifyOtpText">Verify OTP</span>
                    <span id="verifyOtpSpinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
                </button>
                <div class="text-center mt-2">
                    <small class="text-muted">
                        Didn't receive?
                        <button class="btn-link-magic" id="resendBtn" onclick="resendOtp()" disabled>Resend OTP</button>
                        <span id="resendTimer"></span>
                    </small>
                </div>
                <div class="text-center mt-2">
                    <button class="btn-link-magic" onclick="goToStep1()">&#8592; Change Email</button>
                </div>
            </div>

            <!-- STEP 3 -->
            <div id="step3" class="step">
                <h5 class="text-center mb-1">&#128274; Set New Password</h5>
                <p class="text-muted text-center small mb-4">Create a strong new password</p>
                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <input type="password" id="newPassword" class="form-control" placeholder="Enter new password" oninput="checkPasswordStrength()" />
                    <div id="strengthBar" class="strength-bar bg-secondary mt-1" style="width:0%;"></div>
                    <small id="strengthText" class="text-muted"></small>
                </div>
                <div class="mb-3 ps-1">
                    <div id="v-length" class="validation-item invalid">&#10007; Minimum 6 characters</div>
                    <div id="v-upper" class="validation-item invalid">&#10007; At least one upper case</div>
                    <div id="v-number" class="validation-item invalid">&#10007; At least one Numeric</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" id="confirmPassword" class="form-control" placeholder="Re-enter new password" oninput="checkPasswordMatch()" />
                    <small id="matchMsg"></small>
                </div>
                <div id="step3Alert"></div>
                <button class="btn btn-magic w-100 py-2" onclick="resetPassword()">
                    <span id="resetText">Reset Password</span>
                    <span id="resetSpinner" class="spinner-border spinner-border-sm ms-2 d-none"></span>
                </button>
                <div class="text-center mt-3">
                    <button class="btn-link-magic" onclick="showLogin()">&#8592; Back to Login</button>
                </div>
            </div>

            <!-- STEP 4 -->
            <div id="step4" class="step text-center">
                <div style="font-size:4rem;">&#9989;</div>
                <h5 class="mt-3">Password Reset Successful!</h5>
                <p class="text-muted">Your password has been updated.<br />You can now login with your new password.</p>
                <button class="btn btn-magic w-100 py-2" onclick="showLogin()">Go to Login</button>
            </div>

        </div>
    </div>

    <script>
        // ── EMAIL VALIDATION ──────────────────────────────────
      
        var AT = String.fromCharCode(64);
        var emailRegex = new RegExp('^[^\\s' + AT + ']+' + AT + '[^\\s' + AT + ']+\\.[^\\s' + AT + ']+$');

        function isValidEmail(val) {
            return emailRegex.test(val);
        }

        // ── LOGIN FORM VALIDATION ─────────────────────────────
        document.getElementById('loginForm').addEventListener('submit', function (e) {
            var email = document.getElementById('loginEmail').value.trim();
            var password = document.getElementById('loginPassword').value.trim();
            var emailError = document.getElementById('emailError');
            var passwordError = document.getElementById('passwordError');
            var emailInput = document.getElementById('loginEmail');
            var passwordInput = document.getElementById('loginPassword');
            var valid = true;

            emailError.classList.remove('show');
            passwordError.classList.remove('show');
            emailInput.classList.remove('is-invalid');
            passwordInput.classList.remove('is-invalid');

            if (!email) {
                emailError.innerHTML = '<i class="bi bi-exclamation-circle"></i> Please enter your email.';
                emailError.classList.add('show');
                emailInput.classList.add('is-invalid');
                valid = false;
            } else if (!isValidEmail(email)) {
                emailError.innerHTML = '<i class="bi bi-exclamation-circle"></i> Please enter a valid email address.';
                emailError.classList.add('show');
                emailInput.classList.add('is-invalid');
                valid = false;
            }

            if (!password) {
                passwordError.innerHTML = '<i class="bi bi-exclamation-circle"></i> Please enter your password.';
                passwordError.classList.add('show');
                passwordInput.classList.add('is-invalid');
                valid = false;
            }

            if (!valid) { e.preventDefault(); return; }

            document.getElementById('loginText').textContent = 'Signing in...';
            document.getElementById('loginSpinner').classList.remove('d-none');
            document.getElementById('loginBtn').disabled = true;
        });

        document.getElementById('loginEmail').addEventListener('input', function () {
            document.getElementById('emailError').classList.remove('show');
            this.classList.remove('is-invalid');
        });

        document.getElementById('loginPassword').addEventListener('input', function () {
            document.getElementById('passwordError').classList.remove('show');
            this.classList.remove('is-invalid');
        });

        var currentEmail = '';
        var currentOtp = '';
        var otpCountdown;
        var resendCountdown;

        var errorAlert = document.getElementById('errorAlert');
        if (errorAlert) {
            setTimeout(function () {
                errorAlert.classList.add('fade-out');
                setTimeout(function () { errorAlert.remove(); }, 1000);
            }, 3000);
        }

        function showForgotPassword() {
            document.getElementById('loginSection').style.display = 'none';
            document.getElementById('forgotSection').style.display = 'block';
            goToStep1();
        }

        function showLogin() {
            document.getElementById('forgotSection').style.display = 'none';
            document.getElementById('loginSection').style.display = 'block';
            clearAllTimers();
        }

        function goToStep(n) {
            document.querySelectorAll('.step').forEach(function (s) { s.classList.remove('active'); });
            document.getElementById('step' + n).classList.add('active');
        }

        function goToStep1() {
            goToStep(1);
            document.getElementById('fpEmail').value = '';
            document.getElementById('step1Alert').innerHTML = '';
        }

        function showAlert(id, msg, type) {
            if (!type) type = 'danger';
            document.getElementById(id).innerHTML = '<div class="alert alert-' + type + ' py-2 small">' + msg + '</div>';
        }

        function clearAlert(id) { document.getElementById(id).innerHTML = ''; }

        function setLoading(textId, spinnerId, loading) {
            document.getElementById(textId).classList.toggle('d-none', loading);
            document.getElementById(spinnerId).classList.toggle('d-none', !loading);
        }

        function clearAllTimers() {
            clearInterval(otpCountdown);
            clearInterval(resendCountdown);
        }

        // ── STEP 1: Send OTP ──────────────────────────────────
        async function sendOtp() {
            var email = document.getElementById('fpEmail').value.trim();

            if (!email) { showAlert('step1Alert', 'Please enter your email.'); return; }
            if (!isValidEmail(email)) { showAlert('step1Alert', 'Please enter a valid email address.'); return; }

            setLoading('sendOtpText', 'sendOtpSpinner', true);
            clearAlert('step1Alert');
            try {
                var res = await fetch('/Account/SendOtp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(email)
                });
                var data = await res.json();
                if (res.ok) {
                    currentEmail = email;
                    document.getElementById('displayEmail').textContent = email;
                    document.getElementById('otpInput').value = '';
                    clearAlert('step2Alert');
                    goToStep(2);
                    startOtpTimer();
                    startResendTimer();
                } else {
                    showAlert('step1Alert', data.message || 'Failed to send OTP.');
                }
            } catch (e) {
                showAlert('step1Alert', 'Network error. Please try again.');
            } finally {
                setLoading('sendOtpText', 'sendOtpSpinner', false);
            }
        }

        function startOtpTimer() {
            var secs = 5 * 60;
            var el = document.getElementById('otpTimer');
            clearInterval(otpCountdown);
            otpCountdown = setInterval(function () {
                var m = String(Math.floor(secs / 60)).padStart(2, '0');
                var s = String(secs % 60).padStart(2, '0');
                el.textContent = 'OTP expires in ' + m + ':' + s;
                if (--secs < 0) { clearInterval(otpCountdown); el.textContent = 'OTP expired. Please request a new one.'; }
            }, 1000);
        }

        function startResendTimer() {
            var secs = 30;
            var btn = document.getElementById('resendBtn');
            var el = document.getElementById('resendTimer');
            btn.disabled = true;
            clearInterval(resendCountdown);
            resendCountdown = setInterval(function () {
                el.textContent = ' (' + secs + 's)';
                if (--secs < 0) { clearInterval(resendCountdown); btn.disabled = false; el.textContent = ''; }
            }, 1000);
        }

        async function resendOtp() {
            clearInterval(otpCountdown);
            try {
                var res = await fetch('/Account/SendOtp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(currentEmail)
                });
                if (res.ok) {
                    document.getElementById('otpInput').value = '';
                    showAlert('step2Alert', 'New OTP sent to your email!', 'success');
                    startOtpTimer();
                    startResendTimer();
                    setTimeout(function () { clearAlert('step2Alert'); }, 3000);
                }
            } catch (e) { }
        }

        // ── STEP 2: Verify OTP ────────────────────────────────
        async function verifyOtp() {
            var otp = document.getElementById('otpInput').value.trim();
            if (otp.length !== 5) { showAlert('step2Alert', 'Please enter the 5-digit OTP.'); return; }

            setLoading('verifyOtpText', 'verifyOtpSpinner', true);
            clearAlert('step2Alert');
            try {
                var res = await fetch('/Account/VerifyOtp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: currentEmail, otp: otp })
                });
                var data = await res.json();
                if (res.ok) {
                    currentOtp = otp;
                    clearAllTimers();
                    goToStep(3);
                    document.getElementById('newPassword').value = '';
                    document.getElementById('confirmPassword').value = '';
                    resetStrengthUI();
                } else {
                    showAlert('step2Alert', data.message || 'Invalid OTP.');
                }
            } catch (e) {
                showAlert('step2Alert', 'Network error. Please try again.');
            } finally {
                setLoading('verifyOtpText', 'verifyOtpSpinner', false);
            }
        }

        // ── STEP 3: Password Strength ─────────────────────────
        function resetStrengthUI() {
            var bar = document.getElementById('strengthBar');
            bar.style.width = '0%';
            bar.className = 'strength-bar bg-secondary mt-1';
            document.getElementById('strengthText').textContent = '';
            setValid('v-length', false, 'Minimum 6 characters');
            setValid('v-upper', false, 'At least one upper case');
            setValid('v-number', false, 'At least one Numeric');
            document.getElementById('matchMsg').textContent = '';
        }

        function checkPasswordStrength() {
            var pw = document.getElementById('newPassword').value;
            var bar = document.getElementById('strengthBar');
            var text = document.getElementById('strengthText');

            var hasLength = pw.length >= 6;
            var hasUpper = /[A-Z]/.test(pw);
            var hasNumber = /[0-9]/.test(pw);
            var hasSpecial = /[!#$%^&*]/.test(pw);

            setValid('v-length', hasLength, 'Minimum 6 characters');
            setValid('v-upper', hasUpper, 'At least one upper case');
            setValid('v-number', hasNumber, 'At least one Numeric');

            var score = [hasLength, hasUpper, hasNumber, hasSpecial].filter(Boolean).length;
            var colors = ['bg-danger', 'bg-warning', 'bg-info', 'bg-success'];
            var labels = ['Weak', 'Fair', 'Good', 'Strong'];
            var textColors = ['text-danger', 'text-warning', 'text-info', 'text-success'];
            var idx = Math.max(0, score - 1);

            bar.className = 'strength-bar mt-1 ' + colors[idx];
            bar.style.width = (score * 25) + '%';
            text.textContent = pw.length ? labels[idx] : '';
            text.className = 'small ' + textColors[idx];
            checkPasswordMatch();
        }

        function setValid(id, isValid, label) {
            var el = document.getElementById(id);
            el.className = 'validation-item ' + (isValid ? 'valid' : 'invalid');
            el.textContent = (isValid ? '\u2713 ' : '\u2717 ') + label;
        }

        function checkPasswordMatch() {
            var np = document.getElementById('newPassword').value;
            var cp = document.getElementById('confirmPassword').value;
            var msg = document.getElementById('matchMsg');
            if (!cp) { msg.textContent = ''; return; }
            if (np === cp) { msg.textContent = '\u2713 Passwords match'; msg.className = 'small text-success'; }
            else { msg.textContent = '\u2717 Passwords do not match'; msg.className = 'small text-danger'; }
        }

        // ── STEP 3: Reset Password ────────────────────────────
        async function resetPassword() {
            var newPw = document.getElementById('newPassword').value;
            var confirmPw = document.getElementById('confirmPassword').value;

            if (newPw.length < 6) { showAlert('step3Alert', 'Minimum 6 characters required.'); return; }
            if (!/[A-Z]/.test(newPw)) { showAlert('step3Alert', 'At least one upper case letter required.'); return; }
            if (!/[0-9]/.test(newPw)) { showAlert('step3Alert', 'At least one numeric digit required.'); return; }
            if (newPw !== confirmPw) { showAlert('step3Alert', 'Passwords do not match.'); return; }

            setLoading('resetText', 'resetSpinner', true);
            clearAlert('step3Alert');
            try {
                var res = await fetch('/Account/ResetPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: currentEmail, otp: currentOtp, newPassword: newPw, confirmPassword: confirmPw })
                });
                var data = await res.json();
                if (res.ok) { goToStep(4); }
                else { showAlert('step3Alert', data.message || 'Failed to reset password.'); }
            } catch (e) {
                showAlert('step3Alert', 'Network error. Please try again.');
            } finally {
                setLoading('resetText', 'resetSpinner', false);
            }
        }
    </script>
</body>
</html>