@model List<NewMagicPencil.Models.Category>
@{
    ViewData["Title"] = "Category Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-grid"></i> Category Management</h2>
    <div>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-dark me-2">Dashboard</a>
        <a asp-action="Create" class="btn btn-magic">+ Add Category</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table id="categoryTable" class="table table-hover align-middle" style="width:100%">
            <thead class="table-light">
                <tr>
                    <th style="width: 50px;">S.No</th>
                    <th>Category Name</th>
                    <th>Created On</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td class="fw-bold"></td> @* Auto-populated by JavaScript *@
                        <td><strong>@cat.CategoryName</strong></td>
                        <td>@cat.CreatedOn.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            <div class="form-check form-switch d-flex justify-content-center align-items-center gap-2 mb-0">
                                <input class="form-check-input status-switch"
                                       type="checkbox"
                                       role="switch"
                                       id="switch-@cat.Id"
                                       data-id="@cat.Id"
                                       @(cat.Status == "Active" ? "checked" : "")
                                       style="width:2.5em; height:1.3em; cursor:pointer;" />
                                <label class="form-check-label small fw-semibold"
                                       id="label-@cat.Id"
                                       for="switch-@cat.Id"
                                       style="min-width:52px; color:@(cat.Status == "Active" ? "#198754" : "#6c757d");">
                                    @cat.Status
                                </label>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@cat.Id"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="/Category/Upload?categoryId=@cat.Id"
                                   class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-image"></i> Add / View
                                </a>
                                @* <button type="button" class="btn btn-sm btn-outline-danger"
                                        onclick="confirmDelete(@cat.Id, '@Html.Raw(Html.Encode(cat.CategoryName))')">
                                    <i class="bi bi-trash"></i> Delete
                                </button> *@
                            </div>
                            <form id="delete-form-@cat.Id" asp-action="Delete"
                                  method="post" style="display:none;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@cat.Id" />
                                <input type="hidden" name="returnUrl" value="Index" />
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const table = $('#categoryTable').DataTable({
                "order": [[1, "asc"]], // Default sort by Category Name (Column 1) A-Z
                "columnDefs": [
                    {
                        "searchable": false,
                        "orderable": false,
                        "targets": 0 // S.No column fixed
                    }
                ],
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search categories..."
                }
            });

            // ── DYNAMIC S.NO LOGIC ──
            table.on('order.dt search.dt', function () {
                table.column(0, { search: 'applied', order: 'applied' }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            }).draw();

            // Status Toggle logic
            $('.status-switch').on('change', function () {
                var id = $(this).data('id');
                var switchEl = $(this);
                var label = $('#label-' + id);

                switchEl.prop('disabled', true);
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.post('/Category/ToggleStatus', { id: id, __RequestVerificationToken: token }, function (data) {
                    if (data.success) {
                        label.text(data.newStatus).css('color', data.newStatus === 'Active' ? '#198754' : '#6c757d');
                    } else {
                        switchEl.prop('checked', !switchEl.is(':checked'));
                        alert('Error updating status');
                    }
                    switchEl.prop('disabled', false);
                });
            });
        });

        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Permanently Delete?',
                html: 'Delete <strong>' + name + '</strong>?<br/><small class="text-danger">All images will also be deleted.</small>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Yes, Delete!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('delete-form-' + id).submit();
                }
            });
        }
    </script>
}