@model List<NewMagicPencil.Models.Category>
@{
    ViewData["Title"] = "Category Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-grid"></i> Category Management</h2>
    <div>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-dark me-2">Dashboard</a>
        <a asp-action="Create" class="btn btn-magic">+ Add Category</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table id="categoryTable" class="table table-hover align-middle" style="width:100%">
            <thead class="table-light">
                <tr>
                    <th>S.No</th>
                    <th>Category Name</th>
                    <th>Created On</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td></td>
                        <td><strong>@cat.CategoryName</strong></td>
                        <td>@cat.CreatedOn.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            <div class="form-check form-switch d-flex justify-content-center align-items-center gap-2 mb-0">
                                <input class="form-check-input status-switch"
                                       type="checkbox"
                                       role="switch"
                                       id="switch-@cat.Id"
                                       data-id="@cat.Id"
                                       @(cat.Status == "Active" ? "checked" : "")
                                       style="width:2.5em; height:1.3em; cursor:pointer;" />
                                <label class="form-check-label small fw-semibold"
                                       id="label-@cat.Id"
                                       for="switch-@cat.Id"
                                       style="min-width:52px; color:@(cat.Status == "Active" ? "#198754" : "#6c757d");">
                                    @cat.Status
                                </label>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@cat.Id"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                @* <button type="button" class="btn btn-sm btn-outline-danger"
                                        onclick="confirmDelete(@cat.Id, '@Html.Raw(Html.Encode(cat.CategoryName))')">
                                    <i class="bi bi-trash"></i> Delete
                                </button> *@
                                <a href="/Category/Upload?categoryId=@cat.Id"
                                   class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-image"></i> Add / View
                                </a>
                            </div>
                            <form id="delete-form-@cat.Id" asp-action="Delete"
                                  method="post" style="display:none;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@cat.Id" />
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var table = $('#categoryTable').DataTable({
                "order": [[2, "asc"]],
                "language": { "search": "_INPUT_", "searchPlaceholder": "Search categories..." },
                "columnDefs": [{
                    "targets": 0,
                    "orderable": false,
                    "render": function (data, type, row, meta) { return meta.row + 1; }
                }]
            });
            table.on('draw', function () {
                table.column(0, { search: 'applied', order: 'applied' })
                    .nodes().each(function (cell, i) { cell.innerHTML = i + 1; });
            });
        });

        document.querySelectorAll('.status-switch').forEach(function (sw) {
            sw.addEventListener('change', function () {
                var id = this.dataset.id;
                var checked = this.checked;
                var switchEl = this;
                switchEl.disabled = true;

                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                var formData = new FormData();
                formData.append('id', id);
                formData.append('__RequestVerificationToken', token);

                fetch('/Category/ToggleStatus', { method: 'POST', body: formData })
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (data.success) {
                            var label = document.getElementById('label-' + id);
                            label.textContent = data.newStatus;
                            label.style.color = data.newStatus === 'Active' ? '#198754' : '#6c757d';
                        } else {
                            switchEl.checked = !checked;
                            Swal.fire({ icon: 'error', title: 'Error', text: 'Could not update status.' });
                        }
                        switchEl.disabled = false;
                    })
                    .catch(function () {
                        switchEl.checked = !checked;
                        Swal.fire({ icon: 'error', title: 'Error', text: 'Network error.' });
                        switchEl.disabled = false;
                    });
            });
        });

        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Permanently Delete?',
                html: 'Delete <strong>' + name + '</strong>?<br/><small class="text-danger">All images will also be deleted permanently.</small>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete!'
            }).then(function (result) {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Deleting...', allowOutsideClick: false,
                        didOpen: function () { Swal.showLoading(); } });
                    document.getElementById('delete-form-' + id).submit();
                }
            });
        }
    </script>
}