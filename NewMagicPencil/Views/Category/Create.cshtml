@model NewMagicPencil.Controllers.CategoryFormModel
@{
    ViewData["Title"] = "Add Category";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-plus-circle"></i> Add Category</h2>
    <a asp-controller="Category" asp-action="Index" class="btn btn-outline-dark">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form id="categoryForm" asp-action="Create" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Category Name <span class="text-danger">*</span>
                        </label>
                        <input type="text" id="categoryNameInput" name="CategoryName"
                               class="form-control" placeholder="Enter category name"
                               value="@(ViewBag.CategoryName ?? "")" />

                        <div class="field-error" id="categoryNameError"></div>

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger py-2 mt-2 small">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <span>@error.ErrorMessage</span>
                            
                                    <br />
                                }
                            </div>
                        }
                    </div>
                    <button type="submit" id="saveBtn" class="btn btn-success w-100 py-2">
                        <span class="btn-text"><i class="bi bi-floppy"></i> Save Category</span>
                        <span class="spinner-border spinner-border-sm d-none ms-1"></span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <div class="row align-items-center">
                    <div class="col">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul"></i> Categories (A-Z)</h6>
                    </div>
                    <div class="col-md-6">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                            <input type="text" id="catSearchInput" class="form-control bg-light border-start-0" placeholder="Search categories...">
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                @{
                    var categories = ViewBag.AllCategories as List<NewMagicPencil.Models.Category>;
                }
                @if (categories != null && categories.Any())
                {
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0" id="catTable">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th class="ps-3" style="width: 70%">Category Name</th>
                                    <th class="text-end pe-3">Action</th>
                                </tr>
                            </thead>
                            <tbody id="catTableBody">
                                @foreach (var cat in categories)
                                {
                                    <tr>
                                        <td class="ps-3 py-2 category-name-cell">@cat.CategoryName</td>
                                        <td class="text-end pe-3 py-2">
                                            <form asp-action="Delete" asp-route-id="@cat.Id" method="post"
                                                  onsubmit="return confirm('Permanently delete this category?')"
                                                  style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="returnUrl" value="Create" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div id="noResults" class="text-center py-4 text-muted" style="display:none;">
                            <i class="bi bi-search fs-4"></i><br />No categories match your search.
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-4"></i><br />Empty list.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .field-error { color: #d63031; font-size: 0.82rem; margin-top: 4px; display: none; }
    .field-error.show { display: block !important; }
    .border-invalid { border-color: #d63031 !important; box-shadow: none !important; }
    .sticky-top { top: -1px; z-index: 10; }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Real-time Search Logic
            $("#catSearchInput").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                var visibleRows = 0;

                $("#catTableBody tr").filter(function () {
                    var match = $(this).find(".category-name-cell").text().toLowerCase().indexOf(value) > -1;
                    $(this).toggle(match);
                    if(match) visibleRows++;
                });

                // Show "No Results" if everything is hidden
                if(visibleRows === 0 && $("#catTableBody tr").length > 0) {
                    $("#noResults").show();
                    $("#catTable thead").hide();
                } else {
                    $("#noResults").hide();
                    $("#catTable thead").show();
                }
            });

            // Form Validation and Spinner
            $('#categoryForm').on('submit', function (e) {
                var input = $('#categoryNameInput');
                var error = $('#categoryNameError');
                var val = input.val().trim();

                if (!val) {
                    e.preventDefault();
                    error.html('<i class="bi bi-exclamation-circle"></i> Name is required.').addClass('show');
                    input.addClass('border-invalid');
                    return;
                }

                var btn = $('#saveBtn');
                btn.find('.btn-text').html('<i class="bi bi-hourglass-split"></i> Saving...');
                btn.find('.spinner-border').removeClass('d-none');
                btn.prop('disabled', true);
            });

            $('#categoryNameInput').on('input', function () {
                $('#categoryNameError').removeClass('show');
                $(this).removeClass('border-invalid');
            });
        });
    </script>
}