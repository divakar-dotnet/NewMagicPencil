@{
    ViewData["Title"] = "Category Inactive";
    var categoryName = ViewBag.CategoryName;
    var categoryId = ViewBag.CategoryId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-images"></i> Add Images</h2>
    <a asp-action="Index" class="btn btn-outline-dark">
        <i class="bi bi-arrow-left"></i> Back to Categories
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-5 text-center">

        <div style="font-size: 4rem; color: #dee2e6;">
            <i class="bi bi-lock-fill"></i>
        </div>

        <h4 class="mt-3 fw-bold text-secondary">Category is Inactive</h4>

        <p class="text-muted mt-2 mb-1">
            You are trying to access images for:
        </p>
        <h5 class="fw-bold text-dark mb-3">
            <i class="bi bi-folder2"></i> @categoryName
        </h5>

        <div class="alert alert-warning d-inline-block px-4 py-3 rounded-3" style="max-width: 480px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            To upload or view images, the category must be
            <strong>Active</strong>. Please activate the category first, then try again.
        </div>

        <div class="mt-4 d-flex justify-content-center gap-3">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left"></i> Back to Categories
            </a>
            <a asp-action="Edit" asp-route-id="@categoryId" class="btn btn-magic px-4">
                <i class="bi bi-pencil"></i> Edit Category
            </a>
        </div>

    </div>
</div>