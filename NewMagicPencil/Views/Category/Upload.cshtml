@model List<NewMagicPencil.Models.CategoryImage>
@{
    ViewData["Title"] = "Add Images";
    var categoryId = ViewBag.CategoryId;
    var categoryName = ViewBag.CategoryName;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-images"></i> Add Images</h2>
        <p class="text-muted mb-0">Category: <strong>@categoryName</strong></p>
    </div>
    <a asp-action="Index" class="btn btn-outline-dark">
        <i class="bi bi-arrow-left"></i> Back to Categories
    </a>
</div>

@* ── UPLOAD FORM ─────────────────────────────────────────────────── *@
<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-semibold">
        <i class="bi bi-cloud-upload"></i> Upload New Images
    </div>
    <div class="card-body p-4">
        <form id="uploadForm" asp-action="Upload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="categoryId" value="@categoryId" />

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Upload Images <span class="text-danger">*</span>
                </label>
                <input type="file" id="imageInput" name="images"
                       class="form-control" accept=".jpg,.jpeg,.png" multiple />
                <div class="form-text">
                    Allowed: JPG, JPEG, PNG &nbsp;|&nbsp; Maximum: <strong>15 images</strong>
                </div>
                <div id="fileError" class="text-danger small mt-1" style="display:none;"></div>
            </div>

            <div id="previewContainer" class="row g-3 mb-3" style="display:none;"></div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="description" class="form-control" rows="2"
                          placeholder="Write a description..."></textarea>
            </div>

            <button type="submit" id="saveBtn" class="btn btn-success px-4" disabled>
                <span class="btn-text"><i class="bi bi-save"></i> Save Images</span>
                <span class="spinner-border spinner-border-sm d-none ms-1"></span>
            </button>
        </form>
    </div>
</div>

@* ── UPLOADED IMAGES + GALLERY BOX ──────────────────────────────── *@
<div class="row g-4">

    @* LEFT — Uploaded Images *@
    <div class="col-lg-8">
        @if (Model != null && Model.Count > 0)
        {
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-grid-3x3-gap"></i> Uploaded Images
                        <span class="badge bg-primary ms-2">@Model.Count</span>
                        <small class="text-muted ms-2" style="font-weight:normal;">
                            <i class="bi bi-info-circle"></i> Click image to view &nbsp;|&nbsp;
                            <i class="bi bi-grip-vertical"></i> Drag into Gallery Box to add
                        </small>
                    </div>
                    <button id="saveOrderBtn" class="btn btn-sm btn-success d-none" onclick="saveOrder()">
                        <i class="bi bi-save"></i> Save Order
                    </button>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3" id="savedImagesGrid">
                        @foreach (var img in Model)
                        {
                            <div class="col-md-4 col-sm-6 col-6 drag-item"
                                 id="saved-card-@img.Id"
                                 data-id="@img.Id"
                                 data-imgurl="@img.ImageUrl"
                                 draggable="true">
                                <div class="card h-100 shadow-sm position-relative">

                                    @* Drag handle *@
                                    <div style="position:absolute; top:6px; left:6px;
                                                        background:rgba(0,0,0,0.5); color:white;
                                                        border-radius:4px; padding:2px 6px;
                                                        font-size:0.75rem; cursor:grab; z-index:10;"
                                         title="Drag to reorder or drag into Gallery Box">
                                        <i class="bi bi-grip-vertical"></i>
                                    </div>

                                    <img src="@img.ImageUrl"
                                         class="card-img-top"
                                         style="height:160px; object-fit:cover; cursor:pointer;"
                                         alt="Portfolio Image"
                                         onclick="openLightbox('@img.ImageUrl')"
                                         onerror="this.src='/images/no-image.png'; this.onerror=null;" />

                                    <div class="card-body p-2">
                                        <p class="small text-muted mb-0 img-desc" style="min-height:30px;">
                                            @(string.IsNullOrEmpty(img.Description)
                                                                                ? "No description"
                                                                                : img.Description.Length > 50
                                                                                ? img.Description.Substring(0, 50) + "..."
                                                                                : img.Description)
                                        </p>
                                        <p class="small text-muted mt-1 mb-0">
                                            @img.UploadedOn.ToLocalTime().ToString("dd MMM yyyy")
                                        </p>
                                    </div>

                                    <div class="card-footer bg-white p-2">
                                        <div class="d-flex gap-1 justify-content-between">
                                            <button class="btn btn-sm btn-outline-success flex-fill"
                                                    onclick="openEditModal(@img.Id, '@Html.Raw(Html.Encode(img.Description ?? ""))')"
                                                    title="Edit One Liner Description">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <label class="btn btn-sm btn-outline-warning flex-fill mb-0"
                                                   style="cursor:pointer;" title="Replace Image">
                                                <i class="bi bi-arrow-repeat"></i>
                                                <input type="file" class="d-none replace-input"
                                                       accept=".jpg,.jpeg,.png"
                                                       data-id="@img.Id"
                                                       data-categoryid="@categoryId" />
                                            </label>
                                            <button class="btn btn-sm btn-outline-danger flex-fill"
                                                    onclick="deleteImage(@img.Id, @categoryId)"
                                                    title="Delete Image">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i>
                No images uploaded yet. Use the form above to upload.
            </div>
        }
    </div>

    @* RIGHT — Gallery Box *@
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 h-100" id="galleryBoxCard"
             style="border: 2px dashed #6c5ce7 !important; min-height: 300px;">
            <div class="card-header fw-semibold text-white"
                 style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <i class="bi bi-collection"></i> Gallery Box
                <span class="badge bg-white text-dark ms-2" id="galleryCountBadge">0</span>
            </div>

            @* Drop zone *@
            <div id="galleryDropZone" class="card-body d-flex flex-column align-items-center
                 justify-content-center p-4 text-center"
                 style="min-height:220px;">
                <div id="galleryDropHint">
                    <div style="font-size:3rem; color:#a29bfe;">
                        <i class="bi bi-box-arrow-in-down-left"></i>
                    </div>
                    <p class="text-muted mt-2 mb-0">
                        Drag images here<br />
                        <small>to add them to your gallery</small>
                    </p>
                </div>
                <div id="galleryDroppedImages" class="row g-2 w-100" style="display:none!important;"></div>
            </div>

            @* View Gallery button — hidden until at least 1 image added *@
            <div class="card-footer bg-white text-center" id="galleryFooter" style="display:none;">
                <a href="/Category/Gallery?categoryId=@categoryId"
                   class="btn btn-magic w-100">
                    <i class="bi bi-eye"></i> View Gallery
                </a>
            </div>
        </div>
    </div>

</div>

@* ── EDIT DESCRIPTION MODAL ──────────────────────────────────────── *@
<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Edit Description</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editImageId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea id="editDescription" class="form-control" rows="4"
                              placeholder="Enter description..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" onclick="saveEditDescription()">
                    <span id="editSaveText"><i class="bi bi-save"></i> Save</span>
                    <span id="editSaveSpinner" class="spinner-border spinner-border-sm d-none ms-1"></span>
                </button>
            </div>
        </div>
    </div>
</div>

@* ── LIGHTBOX ────────────────────────────────────────────────────── *@
<div id="lightboxModal" style="display:none; position:fixed;
     top:0; left:0; width:100%; height:100%;
     background:rgba(0,0,0,0.92); z-index:9999;
     justify-content:center; align-items:center; flex-direction:column;">
    <button onclick="closeLightbox()" style="position:fixed; top:20px; right:30px;
            background:none; border:none; color:white; font-size:2.5rem;
            cursor:pointer; z-index:10000; line-height:1;">
        &times;
    </button>
    <div style="max-width:90vw; max-height:90vh; display:flex; align-items:center; justify-content:center;">
        <img id="lightboxImg" src="" alt="Full Image"
             style="max-width:90vw; max-height:85vh; object-fit:contain;
                    border-radius:8px; box-shadow:0 0 40px rgba(255,255,255,0.1);" />
    </div>
    <div style="margin-top:12px;">
        <a id="lightboxDownload" href="" download
           style="color:#aaa; font-size:0.85rem; text-decoration:none;">
            <i class="bi bi-download"></i> Download Image
        </a>
    </div>
</div>

<style>
    .drag-item {
        transition: opacity 0.2s;
    }

        .drag-item.dragging {
            opacity: 0.4;
        }

        .drag-item.drag-over > .card {
            outline: 2px dashed #6c5ce7;
            outline-offset: 2px;
        }

    #galleryDropZone.drag-over-zone {
        background: #f0edff;
        border-radius: 8px;
    }

    .gallery-thumb {
        width: 100%;
        height: 80px;
        object-fit: cover;
        border-radius: 6px;
        border: 2px solid #6c5ce7;
    }

    .btn-magic {
        background: #6c5ce7;
        color: white;
        border: none;
    }

        .btn-magic:hover {
            background: #5b4cc4;
            color: white;
        }
</style>

@section Scripts {
    <script src="~/js/upload.js"></script>
    <script>
        var PAGE_CATEGORY_ID = @categoryId;
        var ANTIFORGERY_TOKEN = document.querySelector('input[name="__RequestVerificationToken"]').value;
    </script>
}