@model List<NewMagicPencil.Models.Category>
@{
    ViewData["Title"] = "Select Category - SR Page";
}

<div class="mb-4">
    <h2><i class="bi bi-collection-play"></i> SR Page Selection</h2>
    <p class="text-muted">Select a category to view its specific SR Page images.</p>
</div>

<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        @foreach (var cat in Model)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm border-0 category-card" style="transition: transform 0.2s;">
                    <div class="card-body text-center py-4">
                        <div class="display-6 mb-2 text-primary">
                            <i class="bi bi-folder2-open"></i>
                        </div>
                        <h5 class="card-title fw-bold">@cat.CategoryName</h5>
                        <p class="text-muted small">Manage and like images</p>
                        <a href="/Category/Gallery?categoryId=@cat.Id" class="btn btn-magic w-100 stretched-link">
                            Open SR Page
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No active categories found. Please create a category first.
            </div>
            <a asp-action="Create" class="btn btn-primary">Add Category</a>
        </div>
    }
</div>

<style>
    .category-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    .btn-magic {
        background: #6c5ce7;
        color: white;
        border: none;
    }

        .btn-magic:hover {
            background: #5b4cc4;
            color: white;
        }
</style>