@model List<NewMagicPencil.Models.GalleryImage>
@{
    ViewData["Title"] = "Gallery Module";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>&#10084;&#65039; Gallery Module</h2>
        <p class="text-muted mb-0">All your liked images in one place</p>
    </div>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-dark">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>
</div>

@if (Model != null && Model.Count > 0)
{
    <!-- Group by Category -->
    @foreach (var group in Model.GroupBy(g => g.Category.CategoryName))
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header fw-semibold text-white"
                 style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <i class="bi bi-folder2-open"></i> @group.Key
                <span class="badge bg-white text-dark ms-2">@group.Count()</span>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    @foreach (var img in group)
                    {
                        <div class="col-md-3 col-sm-4 col-6">
                            <div class="card h-100 shadow-sm border-0 position-relative">

                                <!-- Heart badge top right -->
                                <div style="position:absolute; top:8px; right:8px;
                                                        font-size:1.2rem; z-index:10;
                                                        background:white; border-radius:50%;
                                                        width:32px; height:32px;
                                                        display:flex; align-items:center;
                                                        justify-content:center;
                                                        box-shadow:0 2px 6px rgba(0,0,0,0.15);">
                                    &#10084;&#65039;
                                </div>

                                <img src="@img.ImageUrl"
                                     class="card-img-top"
                                     style="height:200px; object-fit:cover; cursor:pointer;"
                                     alt="Gallery Image"
                                     onclick="openLightbox('@img.ImageUrl')"
                                     onerror="this.src='/images/no-image.png'; this.onerror=null;" />

                                <div class="card-body p-2">
                                    <p class="small text-muted mb-0" style="min-height:28px;">
                                        @(string.IsNullOrEmpty(img.Description)
                                                                    ? "No description"
                                                                    : img.Description.Length > 50
                                                                    ? img.Description.Substring(0, 50) + "..."
                                                                    : img.Description)
                                    </p>
                                    <p class="small text-muted mt-1 mb-0">
                                        &#10084; Liked on @img.AddedOn.ToLocalTime().ToString("dd MMM yyyy")
                                    </p>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-5 text-center">
            <div style="font-size:5rem;">&#129293;</div>
            <h4 class="mt-3 fw-bold text-secondary">No Liked Images Yet</h4>
            <p class="text-muted mt-2">
                Go to any category gallery and click the &#10084;&#65039; heart button<br />
                on images you love — they will appear here.
            </p>
            <a asp-controller="Category" asp-action="Index"
               class="btn btn-magic px-4 mt-2">
                <i class="bi bi-grid"></i> Go to Portfolio
            </a>
        </div>
    </div>
}

<!-- Lightbox -->
<div id="lightboxModal" style="display:none; position:fixed;
     top:0; left:0; width:100%; height:100%;
     background:rgba(0,0,0,0.92); z-index:9999;
     justify-content:center; align-items:center; flex-direction:column;">
    <button onclick="closeLightbox()" style="position:fixed; top:20px; right:30px;
            background:none; border:none; color:white; font-size:2.5rem;
            cursor:pointer; z-index:10000; line-height:1;">
        &times;
    </button>
    <div style="max-width:90vw; max-height:90vh;
                display:flex; align-items:center; justify-content:center;">
        <img id="lightboxImg" src="" alt="Full Image"
             style="max-width:90vw; max-height:85vh; object-fit:contain;
                    border-radius:8px; box-shadow:0 0 40px rgba(255,255,255,0.15);" />
    </div>
    <div style="margin-top:12px;">
        <a id="lightboxDownload" href="" download
           style="color:#aaa; font-size:0.85rem; text-decoration:none;">
            <i class="bi bi-download"></i> Download Image
        </a>
    </div>
</div>

<style>
    .btn-magic {
        background: #6c5ce7;
        color: white;
        border: none;
    }

        .btn-magic:hover {
            background: #5b4cc4;
            color: white;
        }
</style>

@section Scripts {
    <script>
        function openLightbox(src) {
            document.getElementById('lightboxImg').src = src;
            document.getElementById('lightboxDownload').href = src;
            document.getElementById('lightboxModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            document.getElementById('lightboxModal').style.display = 'none';
            document.getElementById('lightboxImg').src = '';
            document.body.style.overflow = '';
        }

        document.getElementById('lightboxModal').addEventListener('click', function (e) {
            if (e.target === this) closeLightbox();
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeLightbox();
        });
    </script>
}