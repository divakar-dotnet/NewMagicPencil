@model List<NewMagicPencil.Models.GalleryImage>
@{
    ViewData["Title"] = "Gallery Module";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-heart-fill text-danger"></i> Gallery Module</h2>
        <p class="text-muted mb-0">Your curated collection of liked images</p>
    </div>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-dark">
        <i class="bi bi-speedometer2"></i> Dashboard
    </a>
</div>

@if (Model != null && Model.Count > 0)
{
    @foreach (var group in Model.GroupBy(g => g.Category.CategoryName))
    {
        <div class="card shadow-sm border-0 mb-4 category-group">
            <div class="card-header fw-semibold text-white d-flex justify-content-between align-items-center"
                 style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <span><i class="bi bi-folder2-open"></i> @group.Key</span>
                <span class="badge bg-white text-dark rounded-pill group-count">@group.Count()</span>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    @foreach (var img in group)
                    {
                        <div class="col-md-3 col-sm-4 col-6 gallery-item" id="gallery-card-@img.Id">
                            <div class="card h-100 shadow-sm border-0 position-relative image-hover-card">

                                <button class="btn unlike-btn"
                                        onclick="unlikeImage(@img.Id)"
                                        title="Unlike to remove from Gallery">
                                    <i class="bi bi-heart-fill text-danger"></i>
                                </button>

                                <img src="@img.ImageUrl"
                                     class="card-img-top"
                                     style="height:200px; object-fit:cover; cursor:pointer; border-radius: 8px 8px 0 0;"
                                     alt="Gallery Image"
                                     onclick="openLightbox('@img.ImageUrl')"
                                     onerror="this.src='/images/no-image.png'; this.onerror=null;" />

                                <div class="card-body p-2 border-top">
                                    <p class="small text-muted mb-0 text-truncate">
                                        @(string.IsNullOrEmpty(img.Description) ? "No description" : img.Description)
                                    </p>
                                    <p class="small text-muted mt-1 mb-0" style="font-size: 0.7rem;">
                                        <i class="bi bi-calendar-check"></i> Liked: @img.AddedOn.ToLocalTime().ToString("dd MMM yyyy")
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-5 text-center">
            <div class="display-1 text-light"><i class="bi bi-heartbreak"></i></div>
            <h4 class="mt-3 fw-bold text-secondary">No Liked Images Yet</h4>
            <p class="text-muted">Browse your categories and click the heart icon to add images here.</p>
            <a asp-controller="Category" asp-action="SRList" class="btn btn-magic px-4 mt-2">
                <i class="bi bi-grid"></i> Go to SR Pages
            </a>
        </div>
    </div>
}

@* Lightbox Modal *@
<div id="lightboxModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:9999; justify-content:center; align-items:center;" onclick="closeLightbox()">
    <button class="btn text-white" style="position:fixed; top:20px; right:30px; font-size:2.5rem;">&times;</button>
    <img id="lightboxImg" src="" style="max-width:90vw; max-height:85vh; object-fit:contain; border-radius:8px;" />
</div>

<style>
    .btn-magic {
        background: #6c5ce7;
        color: white;
        border: none;
    }

        .btn-magic:hover {
            background: #5b4cc4;
            color: white;
        }

    .image-hover-card {
        transition: transform 0.3s ease;
    }

        .image-hover-card:hover {
            transform: translateY(-5px);
        }

    .unlike-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        background: white;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        border: none;
        padding: 0;
        transition: all 0.2s ease;
    }

        .unlike-btn:hover {
            transform: scale(1.2);
            background: #fff5f5;
        }

        .unlike-btn i {
            font-size: 1.1rem;
            line-height: 1;
        }
</style>

@section Scripts {
    <script>
        function unlikeImage(id) {
            Swal.fire({
                title: 'Remove from Gallery?',
                text: "This will 'Unlike' the image and hide it from this page.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#6c5ce7',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, Unlike'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Category/ToggleLike', { id: id }, function (data) {
                        if (data.success) {
                            // Smoothly remove from UI
                            $('#gallery-card-' + id).fadeOut(400, function() {
                                var group = $(this).closest('.category-group');
                                $(this).remove();

                                // Update the count badge for that category
                                var countBadge = group.find('.group-count');
                                var newCount = parseInt(countBadge.text()) - 1;
                                countBadge.text(newCount);

                                // If no images left in this category group, remove the whole group
                                if (newCount === 0) {
                                    group.fadeOut(400, function() {
                                        $(this).remove();
                                        // If no categories left at all, reload to show empty state
                                        if($('.category-group').length === 0) location.reload();
                                    });
                                }
                            });
                        }
                    });
                }
            });
        }

        function openLightbox(src) {
            $('#lightboxImg').attr('src', src);
            $('#lightboxModal').css('display', 'flex');
            $('body').css('overflow', 'hidden');
        }

        function closeLightbox() {
            $('#lightboxModal').hide();
            $('body').css('overflow', 'auto');
        }
    </script>
}